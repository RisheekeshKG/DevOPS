    {
      "title": "Risk Score Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 16 },
      "id": 5,
      "datasource": { "type": "influxdb", "uid": "" },
      "targets": [
        {
          "query": "from(bucket: \"patient_vitals\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\" and r._field == \"risk_score\")\n  |> aggregateWindow(every: 10s, fn: last, createEmpty: false)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "always",
            "thresholdsStyle": { "mode": "line" }
          },
          "min": 0,
          "max": 1,
          "displayName": "${__field.labels.patient_id}",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 0.7 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max", "mean"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Risk Label Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 6,
      "datasource": { "type": "influxdb", "uid": "" },
      "targets": [
        {
          "query": "from(bucket: \"patient_vitals\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\" and r._field == \"risk_score\")\n  |> group(columns: [\"risk_label\"])\n  |> count()",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "🚨 High Risk Alerts (Last 30 min)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 7,
      "datasource": { "type": "influxdb", "uid": "" },
      "targets": [
        {
          "query": "from(bucket: \"patient_vitals\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\" and r._field == \"risk_score\" and r.risk_label == \"high\")\n  |> keep(columns: [\"_time\", \"patient_id\", \"ward\", \"bed\", \"scenario\", \"_value\"])\n  |> rename(columns: {_value: \"risk_score\", _time: \"time\"})\n  |> sort(columns: [\"time\"], desc: true)\n  |> limit(n: 50)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "risk_score" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "orange", "value": null },
                    { "color": "red", "value": 0.7 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "time", "desc": true }]
      }
    },
    {
      "title": "ECG (All Patients)",

    {
      "title": "Heart Rate (All Patients)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "datasource": { "type": "influxdb", "uid": "" },
      "targets": [
        {
          "query": "from(bucket: \"patient_vitals\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"patient_vitals\" and r._field == \"hr\")\n  |> aggregateWindow(every: 10s, fn: last, createEmpty: false)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "bpm",
          "displayName": "${__field.labels.patient_id}"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
